#!/bin/sh
# hyprbind — zero-dependency Hyprland keybind generator
# POSIX sh + awk. No Python, no fzf, no nothing else.
# https://github.com/<YOUR_USER>/hyprbind

# ── Usage ──────────────────────────────────────────────────────────
usage() {
    cat <<'EoU'
Usage: hyprbind [OPTIONS] [SELECTION]

SELECTION (skip for interactive TUI):
  --all           Include all binds
  1,3,5-9         Bind numbers/ranges (from --list)
  --list          Show numbered list of all binds

OPTIONS:
  --format conf   hyprland.conf output (default)
  --format lua    end-4 Caelestia Lua output
  -o, --output DIR   Write files to DIR instead of stdout

Examples:
  hyprbind                                    # TUI → stdout
  hyprbind --all -o ~/hypr/                   # all binds to files
  hyprbind --list                             # see numbers
  hyprbind 1,3,5-7,10                         # pick by number
EoU
}

